LLM_API_KEY=lm-studio
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=<your-lm-studio-model-id>
LLM_TIMEOUT_SECONDS=300
EMBEDDING_MODEL=all-MiniLM-L6-v2
VECTOR_STORE_DIR=.rag_store
# Optional: cross-encoder reranker model (leave empty to disable)
# RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# Vector store backend: "chroma" (default, scalable) or "local" (legacy JSON file)
# VECTOR_STORE_BACKEND=chroma
# Default state of the "Hybrid search" checkbox in the UI (BM25 + embeddings via RRF)
# HYBRID_SEARCH=false

